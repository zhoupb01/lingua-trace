# Optional production build overrides for ./deploy/push.sh.
#
# push.sh layers this ON TOP of .env (values here win), so keep your dev .env for
# local work and put ONLY what the *production build* needs differently here.
# At build/push time the sole baked-in, env-specific values are the web bundle's
# VITE_* (see docker-compose.build.yml); the api's runtime config comes from the
# server's own .env, not from here, so it doesn't belong in this file.
#
# Use:  cp .env.production.example .env.production   (then fill in; it's gitignored)

VITE_LOGTO_ENDPOINT=https://auth.zhoupb.com
VITE_LOGTO_APP_ID=
VITE_LOGTO_API_RESOURCE=https://api.myapp.example.com

VITE_EXTENSION_API_BASE_URL=https://myapp.example.com/api
VITE_EXTENSION_LOGTO_ENDPOINT=https://auth.zhoupb.com
VITE_EXTENSION_LOGTO_APP_ID=
VITE_EXTENSION_LOGTO_API_RESOURCE=https://api.myapp.example.com

# Only if your prod registry/tag differ from .env (PROJECT_SLUG is env-agnostic):
# REGISTRY=registry.cn-hangzhou.aliyuncs.com/zhoupb
# IMAGE_TAG=latest

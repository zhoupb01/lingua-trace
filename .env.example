# ── identity ──────────────────────────────────────────────────────────────────
# One environment's .env. Provision per env: ./provision.sh <slug> <env>
# (this example is the `dev` environment of `myapp`). PROJECT_SLUG stays
# env-agnostic — the image is the same for dev/prod; the environment shows up in
# the DB / KV / AppRole / domain below.
PROJECT_SLUG=myapp
DOMAIN=dev.myapp.example.com

# ── deploy · image registry (build locally → push → server pulls) ─────────────
REGISTRY=registry.cn-hangzhou.aliyuncs.com/zhoupb
IMAGE_TAG=latest

# ── API · OpenBao (AppRole — one per slug+env) ────────────────────────────────
# secret_id is injected here at deploy; everything else is non-secret config.
OPENBAO_ADDR=https://openbao.zhoupb.com
OPENBAO_APPROLE_MOUNT=approle
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=
OPENBAO_KV_MOUNT=kv
OPENBAO_KV_PATH=myapp/dev        # <slug>/<env> — NO `data`; secrets.ts reads kv/data/<path>
OPENBAO_DB_MOUNT=database
OPENBAO_DB_ROLE=myapp-dev        # OpenBao static-role name (<slug>-<env>)

# ── API · Postgres (shared instance; this env's own database) ─────────────────
# PG_HOST = the Postgres container name, reachable on the shared postgres_default network.
PG_HOST=postgres18
PG_PORT=5432
PG_DATABASE=myapp-dev

# ── API · Logto (token audience = the API resource indicator) ─────────────────
LOGTO_ENDPOINT=https://auth.zhoupb.com
LOGTO_API_RESOURCE=https://api.dev.myapp.example.com

# ── API · OpenAI / Agents SDK (the API key lives in OpenBao KV, not here) ──────
OPENAI_MODEL=gpt-5.1
# Optional — target an OpenAI-compatible endpoint (default: OpenAI's own).
# OPENAI_BASE_URL=https://api.openai.com/v1
# Use the Responses API (server-side state — previous_response_id, so a turn sends
# only the new message)? Defaults to true on OpenAI, false when OPENAI_BASE_URL is
# set (most compatible endpoints only do /chat/completions). Override if yours differs.
OPENAI_USE_RESPONSES=true

PORT=3000
# fatal|error|warn|info|debug|trace|silent — default info
LOG_LEVEL=info

# ── WEB · public client config (baked into the bundle at build time) ──────────
VITE_LOGTO_ENDPOINT=https://auth.zhoupb.com
VITE_LOGTO_APP_ID=
VITE_LOGTO_API_RESOURCE=https://api.dev.myapp.example.com

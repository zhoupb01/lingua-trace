{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "types": ["chrome", "vite/client"],
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./src/*"],
            "@app/shared": ["../../packages/shared/src/index.ts"],
            "@app/shared/*": ["../../packages/shared/src/*"]
        }
    },
    "include": ["src", "vite.config.ts", "../../packages/shared/src"]
}

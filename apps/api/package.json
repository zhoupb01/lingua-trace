{
    "name": "@app/api",
    "private": true,
    "type": "module",
    "module": "src/index.ts",
    "exports": {
        ".": {
            "types": "./src/app.ts",
            "default": "./src/index.ts"
        }
    },
    "scripts": {
        "dev": "bun --env-file=../../.env --hot src/index.ts | pino-pretty",
        "start": "bun src/index.ts",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun --env-file=../../.env src/index.ts migrate",
        "db:studio": "bun scripts/db.ts studio",
        "test": "bun test"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.8.0",
        "openai": "^6.44.0",
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.26",
        "jose": "^6.2.3",
        "pino": "^10.3.1",
        "postgres": "^3.4.9",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.5.3",
        "bun-types": "^1.3.14",
        "drizzle-kit": "^0.31.10",
        "pino-pretty": "^13.1.3",
        "typescript": "^6.0.3"
    }
}
